# Virtual environments (4.8G — never track)
.venv*/

# Data & run outputs (large / regenerable — not version controlled)
data/
runs/
logs/

# Generated reports
*.pdf

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Editor / OS
.DS_Store

# stray logs anywhere
*.log

# LaTeX build artifacts (keep .tex/.bib/.bbl; .pdf already ignored above)
*.aux
*.out
*.synctex.gz
*.blg
*.toc
*.fls
*.fdb_latexmk

# Claude Code local/runtime
.claude/

# transient Isaac progress files (container-written, all variants)
fem_progress*.txt
convergence.txt

# scratch working dir (regenerable subsets, ad-hoc scripts, logs)
scratchpad/

# Codex handoff scratch area (task/report .md + logs) — not version controlled
codex/
